# DataGuard local configuration. Copy to `.env` (which is git-ignored).
# All values are local-only and non-secret.

# --- Postgres (matches monorepo CONVENTIONS: port 5434, db 'dataguard') ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dataguard

# Host-exposed ports (override to avoid collisions).
DATAGUARD_PG_PORT=5434
DATAGUARD_API_PORT=8201
DATAGUARD_DASHBOARD_PORT=8501

# --- Connection settings used by the Python services -----------------------
# Inside docker-compose these are overridden to point at the `postgres` service
# on its internal port 5432. The defaults below are for running tools/scripts
# against the published port from the host.
DATAGUARD_PG_HOST=localhost
DATAGUARD_PG_DB=dataguard
DATAGUARD_PG_USER=postgres
DATAGUARD_PG_PASSWORD=postgres

# API base URL the Streamlit dashboard talks to (compose overrides to api:8201).
DATAGUARD_API_URL=http://localhost:8201
