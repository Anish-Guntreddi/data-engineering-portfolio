# StreamPulse environment. Copy to .env (git-ignored) and adjust if needed.
# All values are local-only and non-secret.

# ---- Host-published ports (see CONVENTIONS.md port allocation) ----
POSTGRES_PORT=5435            # host -> postgres:5432
REDPANDA_PORT=19092          # host -> redpanda kafka API
REDPANDA_CONSOLE_PORT=8090   # host -> redpanda console:8080
DASHBOARD_PORT=8502          # host -> streamlit:8501

# ---- Postgres (local creds, non-secret) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=streampulse

# libpq vars consumed by the python services (in-network hostnames/ports)
PGHOST=postgres
PGPORT=5432
PGDATABASE=streampulse
PGUSER=postgres
PGPASSWORD=postgres

# ---- Kafka / Redpanda ----
KAFKA_BOOTSTRAP=redpanda:9092
EVENTS_TOPIC=events

# ---- Pipeline tuning ----
WINDOW_SECONDS=60            # tumbling window size
FLUSH_SECONDS=5             # processor metric upsert interval
PRODUCE_RATE=8             # producer baseline events/sec
PRODUCER_SEED=7            # deterministic generator seed
BURST_EVERY=50            # producer burst cadence (events); 0 disables
BURST_MULTIPLIER=12      # events per tick during a burst

# ---- Alerting thresholds ----
EPM_MAX=300              # alert when events_per_minute > EPM_MAX
CONV_MIN=0.02           # alert when conversion_rate < CONV_MIN
POLL_SECONDS=5
LOOKBACK_WINDOWS=20

# ---- Dashboard ----
REFRESH_SECONDS=5
