# WarehouseLab environment. Copy to `.env` (git-ignored) and adjust if needed.
# These are LOCAL, NON-SECRET credentials per the monorepo conventions.

# --- Postgres (container-internal port is always 5432) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=warehouse

# --- Host port mappings (per CONVENTIONS.md port allocation) ---
HOST_PG_PORT=5433
HOST_DAGSTER_PORT=3333
HOST_METABASE_PORT=3030

# --- dbt connection (used by warehouse_dbt/profiles.yml via env_var) ---
# Inside compose these point at the `postgres` service on its internal port.
DBT_PG_HOST=postgres
DBT_PG_PORT=5432
DBT_PG_USER=postgres
DBT_PG_PASSWORD=postgres
DBT_PG_DATABASE=warehouse
